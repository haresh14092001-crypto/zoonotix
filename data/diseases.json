// Inject metadata on load
Object.keys(diseases).forEach(cat => {
  diseases[cat].forEach(d => {
    const meta = diseaseMetadata[d.id] || {};
    d.group = meta.group || cat;
    d.transmissionTypes = meta.transmission || [];
    d.hostTypes = meta.hosts || [];
    d.tags = meta.tags || [];
  });
});

