const colorMap = {
bacterial: '#e8a838',
viral: '#e84444',
fungal: '#7dc45e',
parasitic: '#9b72cf',
prion: '#e84497'
};

const diseases = {
bacterial: [
{
id: 'anthrax', name: 'Anthrax', aka: 'Woolsorter\'s Disease / Malignant Pustule',
agent: 'Bacillus anthracis', badge: 'OIE Notifiable', danger: 'high',
reservoir: 'Cattle, sheep, goats, horses, soil spores',
vector: 'Direct contact / spore inhalation / contaminated animal products',
hosts: ['Cattle', 'Sheep', 'Goats', 'Horses', 'Wild herbivores'],
humanRisk: 'Cutaneous (95%), inhalation (rare), gastrointestinal',
incubation: '1-5 days (cutaneous); 1-5 days (inhalation)',
