<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ZoonotiX - Veterinary Zoonotic Disease Encyclopedia</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
	--bg: #0b0f1a;
	--surface: #111827;
	--surface2: #1a2332;
	--border: #1e3a5f;
	--accent: #00d4aa;
	--accent2: #ff6b35;
	--accent3: #7c5cbf;
	--text: #e8f0fe;
	--muted: #6b8cae;
	--bacterial: #e8a838;
	--viral: #e84444;
	--fungal: #7dc45e;
	--parasitic: #9b72cf;
	--prion: #e84497;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
	background: var(--bg);
	color: var(--text);
	font-family: 'DM Sans', sans-serif;
	min-height: 100vh;
	overflow-x: hidden;
}

/* Background grid */
body::before {
	content: "";
	position: fixed;
	inset: 0;
	background-image:
		linear-gradient(rgba(0,212,170,0.04) 1px, transparent 1px),
		linear-gradient(90deg, rgba(0,212,170,0.04) 1px, transparent 1px);
	background-size: 48px 48px;
	pointer-events: none;
	z-index: 0;
}

/* Glow orbs */
body::after {
	content: "";
	position: fixed;
	top: -200px; left: -200px;
	width: 600px; height: 600px;
	background: radial-gradient(circle, rgba(0,212,170,0.06) 0%, transparent 70%);
	pointer-events: none;
	z-index: 0;
}

/* HEADER */
header {
	position: relative; z-index: 10;
	padding: 40px 48px 0;
	border-bottom: 1px solid var(--border);
	background: linear-gradient(180deg, rgba(0,212,170,0.04) 0%, transparent 100%);
}

.header-inner { max-width: 1200px; margin: 0 auto; }

.logo-row { display: flex; align-items: center; gap: 14px; margin-bottom: 8px; }

.logo-icon {
	width: 44px; height: 44px;
	background: linear-gradient(135deg, var(--accent), #0099ff);
	border-radius: 12px;
	display: flex; align-items: center; justify-content: center;
	font-size: 22px;
}

.logo-text {
	font-family: 'Playfair Display', serif;
	font-size: 28px; font-weight: 900;
	letter-spacing: -0.5px;
	color: var(--accent);
}

.logo-text span { color: var(--text); }

.header-subtitle {
	font-family: 'DM Mono', monospace;
	font-size: 11px;
	color: var(--muted);
	letter-spacing: 3px;
	text-transform: uppercase;
	margin-bottom: 28px;
	padding-left: 58px;
}

nav { display: flex; gap: 4px; padding-bottom: 0; }

.nav-tab {
	padding: 10px 20px;
	font-family: 'DM Mono', monospace;
	font-size: 12px;
	letter-spacing: 1px;
	text-transform: uppercase;
	border: none; cursor: pointer;
	background: transparent;
	color: var(--muted);
	border-bottom: 2px solid transparent;
	transition: all 0.2s;
	position: relative; bottom: -1px;
}

.nav-tab:hover { color: var(--text); }
.nav-tab.active { color: var(--accent); border-bottom-color: var(--accent); }

/* MAIN */
main { position: relative; z-index: 5; max-width: 1200px; margin: 0 auto; padding: 48px; }

/* VIEWS */
.view { display: none; animation: fadeIn 0.35s ease; }
.view.active { display: block; }

@keyframes fadeIn {
from { opacity: 0; transform: translateY(12px); }
to { opacity: 1; transform: translateY(0); }
}

/* HOME / CATEGORY VIEW */
.section-title {
font-family: 'Playfair Display', serif;
font-size: 36px; font-weight: 700;
margin-bottom: 8px;
line-height: 1.2;
}

.section-desc {
	color: var(--muted);
	font-size: 14px; line-height: 1.6;
	margin-bottom: 40px;
	max-width: 600px;
}

.categories-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }

.cat-card {
	background: var(--surface);
	border: 1px solid var(--border);
	border-radius: 16px;
	padding: 28px;
	cursor: pointer;
	transition: all 0.25s;
	position: relative;
	overflow: hidden;
}

.cat-card::before { content: ""; position: absolute; inset: 0; opacity: 0; transition: opacity 0.25s; }

.cat-card:hover { transform: translateY(-3px); border-color: transparent; }
.cat-card:hover::before { opacity: 1; }

.cat-card[data-cat="bacterial"] { --cc: var(--bacterial); }
.cat-card[data-cat="viral"] { --cc: var(--viral); }
.cat-card[data-cat="fungal"] { --cc: var(--fungal); }
.cat-card[data-cat="parasitic"] { --cc: var(--parasitic); }
.cat-card[data-cat="prion"] { --cc: var(--prion); }

.cat-card:hover { box-shadow: 0 0 0 1px var(--cc), 0 16px 48px rgba(0,0,0,0.4); }

.cat-emoji { font-size: 36px; margin-bottom: 16px; display: block; }

.cat-name {
	font-family: 'Playfair Display', serif;
	font-size: 22px; font-weight: 700;
	color: var(--cc);
	margin-bottom: 8px;
}

.cat-desc { font-size: 13px; color: var(--muted); line-height: 1.5; margin-bottom: 16px; }

.cat-count {
	font-family: 'DM Mono', monospace;
	font-size: 11px; color: var(--cc);
	letter-spacing: 1px;
	opacity: 0.7;
}

.cat-arrow {
	position: absolute; right: 24px; bottom: 24px;
	width: 32px; height: 32px;
	border: 1px solid var(--cc);
	border-radius: 50%;
	display: flex; align-items: center; justify-content: center;
	color: var(--cc);
	font-size: 14px;
	opacity: 0.5;
	transition: opacity 0.2s;
}

.cat-card:hover .cat-arrow { opacity: 1; }

/* DISEASE LIST VIEW */
.back-btn {
	display: inline-flex; align-items: center; gap: 8px;
	background: transparent; border: 1px solid var(--border);
	color: var(--muted); padding: 8px 16px;
	border-radius: 8px; cursor: pointer;
	font-size: 13px; font-family: 'DM Sans', sans-serif;
	margin-bottom: 32px;
	transition: all 0.2s;
}

.back-btn:hover { border-color: var(--accent); color: var(--accent); }

.breadcrumb {
	font-family: 'DM Mono', monospace;
	font-size: 11px; color: var(--muted);
	letter-spacing: 2px; text-transform: uppercase;
	margin-bottom: 8px;
}

.breadcrumb span { color: var(--accent); }

.disease-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 16px; margin-top: 32px; }

.disease-card {
	background: var(--surface);
	border: 1px solid var(--border);
	border-radius: 12px;
	padding: 22px 24px;
	cursor: pointer;
	transition: all 0.2s;
	display: flex; align-items: center; gap: 16px;
}

.disease-card:hover { border-color: var(--cc, var(--accent)); transform: translateX(4px); background: var(--surface2); }

.disease-num {
font-family: 'DM Mono', monospace;
font-size: 11px;
color: var(--cc, var(--accent));
opacity: 0.6;
min-width: 28px;
}

.disease-info { flex: 1; }

.disease-name {
font-weight: 600; font-size: 15px;
margin-bottom: 3px;
}

.disease-aka {
font-size: 12px; color: var(--muted);
font-style: italic;
}

.disease-badge {
font-family: 'DM Mono', monospace;
font-size: 10px; letter-spacing: 1px;
padding: 3px 8px;
border-radius: 4px;
background: rgba(0,212,170,0.08);
color: var(--cc, var(--accent));
border: 1px solid rgba(0,212,170,0.15);
white-space: nowrap;
}

/* ENCYCLOPEDIA VIEW */
.ency-header {
margin-bottom: 40px;
padding-bottom: 32px;
border-bottom: 1px solid var(--border);
}

.ency-category-tag {
display: inline-flex; align-items: center; gap: 6px;
font-family: 'DM Mono', monospace;
font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
padding: 5px 12px; border-radius: 20px;
margin-bottom: 16px;
border: 1px solid;
}

.ency-title {
font-family: 'Playfair Display', serif;
font-size: 48px; font-weight: 900;
line-height: 1.1; margin-bottom: 8px;
letter-spacing: -1px;
}

.ency-subtitle {
font-size: 16px; color: var(--muted);
margin-bottom: 20px;
}

.ency-meta {
display: flex; gap: 24px; flex-wrap: wrap;
}

.meta-pill {
display: flex; align-items: center; gap: 8px;
background: var(--surface); border: 1px solid var(--border);
border-radius: 8px; padding: 8px 16px;
font-size: 13px;
}

.meta-label {
font-family: 'DM Mono', monospace;
font-size: 10px; color: var(--muted);
letter-spacing: 1px; text-transform: uppercase;
}

.meta-value { font-weight: 500; }

/* Encyclopedia sections */
.ency-body {
display: grid;
grid-template-columns: 1fr 320px;
gap: 40px;
align-items: start;
}

@media (max-width: 900px) {
.ency-body { grid-template-columns: 1fr; }
}

.ency-sections { display: flex; flex-direction: column; gap: 32px; }

.ency-section {
background: var(--surface);
border: 1px solid var(--border);
border-radius: 14px;
overflow: hidden;
}

.section-header {
display: flex; align-items: center; gap: 12px;
padding: 18px 24px;
background: var(--surface2);
border-bottom: 1px solid var(--border);
}

.section-icon { font-size: 18px; }

.section-name {
font-family: 'DM Mono', monospace;
font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
color: var(--accent);
}

.section-body { padding: 24px; }

.section-body p {
font-size: 14px; line-height: 1.75;
color: #c4d4e8;
margin-bottom: 12px;
}

.section-body p:last-child { margin-bottom: 0; }

/* Key-value pairs */
.kv-list { display: flex; flex-direction: column; gap: 12px; }

.kv-item {
display: flex; gap: 16px;
font-size: 13px; line-height: 1.5;
}

.kv-key {
font-family: 'DM Mono', monospace;
font-size: 11px; color: var(--muted);
min-width: 120px; padding-top: 2px;
letter-spacing: 0.5px;
}

.kv-val { color: var(--text); flex: 1; }

/* Chain of transmission visual */
.transmission-chain {
display: flex; align-items: center;
gap: 8px; flex-wrap: wrap;
margin-top: 12px;
}

.tc-node {
background: var(--surface2);
border: 1px solid var(--border);
border-radius: 8px; padding: 8px 14px;
font-size: 13px; font-weight: 500;
text-align: center;
}

.tc-node.host { border-color: var(--accent); color: var(--accent); }
.tc-node.vector { border-color: var(--accent2); color: var(--accent2); }
.tc-node.human { border-color: #4fc3f7; color: #4fc3f7; }

.tc-arrow {
color: var(--muted); font-size: 18px;
}

/* Sidebar */
.ency-sidebar { display: flex; flex-direction: column; gap: 20px; }

.sidebar-card {
background: var(--surface);
border: 1px solid var(--border);
border-radius: 14px;
padding: 20px;
}

.sidebar-card-title {
font-family: 'DM Mono', monospace;
font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
color: var(--muted); margin-bottom: 14px;
display: flex; align-items: center; gap: 8px;
}

.danger-badge {
display: inline-flex; align-items: center; gap: 6px;
padding: 6px 14px; border-radius: 6px;
font-weight: 600; font-size: 14px;
margin-bottom: 8px;
}

.danger-badge.high { background: rgba(232,68,68,0.15); color: #e84444; border: 1px solid rgba(232,68,68,0.3); }
.danger-badge.medium { background: rgba(232,168,56,0.15); color: var(--bacterial); border: 1px solid rgba(232,168,56,0.3); }
.danger-badge.low { background: rgba(125,196,94,0.15); color: var(--fungal); border: 1px solid rgba(125,196,94,0.3); }

.tag-cloud { display: flex; flex-wrap: wrap; gap: 6px; }

.tag {
font-size: 11px; padding: 4px 10px;
background: var(--surface2); border: 1px solid var(--border);
border-radius: 4px; color: var(--muted);
}

.quick-facts { display: flex; flex-direction: column; gap: 10px; }

.qf-row {
display: flex; justify-content: space-between;
align-items: center;
padding: 10px 0;
border-bottom: 1px solid var(--border);
font-size: 13px;
}

.qf-row:last-child { border-bottom: none; }
.qf-label { color: var(--muted); font-size: 12px; }
.qf-val { font-weight: 500; font-family: 'DM Mono', monospace; font-size: 12px; }

/* ABOUT VIEW */
.about-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 24px; margin-top: 32px;
}

.about-card {
background: var(--surface);
border: 1px solid var(--border);
border-radius: 14px; padding: 28px;
}

.about-card h3 {
font-family: 'Playfair Display', serif;
font-size: 18px; margin-bottom: 12px;
color: var(--accent);
}

.about-card p { font-size: 13px; color: var(--muted); line-height: 1.7; }

.syllabus-list {
list-style: none; margin-top: 12px;
}

.syllabus-list li {
padding: 8px 0;
border-bottom: 1px solid var(--border);
font-size: 13px; color: var(--muted);
display: flex; align-items: center; gap: 8px;
}

.syllabus-list li::before { content: '→'; color: var(--accent); font-family: 'DM Mono'; }

/* Search bar */
.search-bar {
display: flex; align-items: center; gap: 12px;
background: var(--surface);
border: 1px solid var(--border);
border-radius: 12px;
padding: 12px 18px;
margin-bottom: 32px;
transition: border-color 0.2s;
}

.search-bar:focus-within { border-color: var(--accent); }

.search-bar input {
flex: 1; background: transparent; border: none; outline: none;
color: var(--text); font-size: 14px; font-family: 'DM Sans', sans-serif;
}

.search-bar input::placeholder { color: var(--muted); }

.search-icon { color: var(--muted); font-size: 16px; }
</style>

